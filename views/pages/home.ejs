<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">

        <title>The Pokemon App - Home</title>

        <link href="/styles/home.css" rel="stylesheet">
        <link href="/styles/global.css" rel="stylesheet">
        <link rel="icon" href="/images/pokeball.png">

        <script src="/scripts/home.js" type="module"></script>
        <script src="/scripts/global.js" type="module"></script>
    </head>
    <body id="home-body">
        <%- include('../partials/header') %>
        <main>
            <div class="search-section">
                <div class="search-wrapper">
                    <input 
                        type="text" 
                        id="pokemon-search" 
                        placeholder="Search Pokémon..."
                    >
                    <button id="filter-button">
                        Filters
                    </button>
                </div>
                <div class="filter-panel" id="filter-panel" style="display:none;">
                    <div class="filter-types" id="filter-types"></div>
                    <div class="filter-actions">
                        <button id="confirm-filters" class="filter-btn confirm-btn">Confirm</button>
                        <button id="clear-filters" class="filter-btn clear-btn">Clear All</button>
                    </div>
                </div>
            </div>
            <div id="active-filters" class="active-filters"></div>
            <div class="stats-section">
                <div id="primary-stat"></div>
                <div id="stats-container" class="stats-grid"></div>
            </div>
            <div id="loading" class="loading-spinner" style="display:none;"></div>
            <div class="card-container" id="pokemon-container">

            </div>
            <div id="pagination" class="pagination-container">
                <span id="pagination-info"></span>
                <div class="pagination-buttons">
                    <button id="prev-page">Previous</button>
                    <button id="next-page">Next</button>
                </div>
            </div>
        </main>
        <%- include('../partials/footer') %>
    </body>
</html>